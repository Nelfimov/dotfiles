prefix_rule(pattern=["cargo", "test"], decision="allow")
prefix_rule(pattern=["dig", "+short"], decision="allow")
prefix_rule(pattern=["nix", "flake", "show"], decision="allow")
prefix_rule(pattern=["nix", "build"], decision="allow")
prefix_rule(pattern=["nix", "log"], decision="allow")
prefix_rule(pattern=["nix", "path-info"], decision="allow")
prefix_rule(pattern=["nix", "why-depends"], decision="allow")
prefix_rule(pattern=["tar", "-tzf", "result"], decision="allow")
prefix_rule(pattern=["yarn", "jest"], decision="allow")
prefix_rule(pattern=["curl", "-s"], decision="allow")
